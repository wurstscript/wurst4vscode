{
	"compilerOptions": {
		"target": "es6",
		"module": "node16",
		"moduleResolution": "node16",
		"outDir": "out",
		"rootDir": "src",
		"lib": [ "es6" ],
		"types": ["node"],
		"sourceMap": true,
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"strict": true,
		"skipLibCheck": true
	},
	"exclude": [
		"node_modules",
		"server",
		"src/webview"
	]
}
