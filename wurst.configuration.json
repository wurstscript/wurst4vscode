{
    "comments": {
        "lineComment": "//",
        "blockComment": [ "/*", "*/" ]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"],
        ["<", ">"]
    ],
    "colorizedBracketPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "onEnterRules": [
        {
            "beforeText": "^\\s*(?:((if|while|for|function|class|module|enum|interface|case|switch)\\b.*)|(begin|ondestroy|init)|(construct|else|elseif).*)|.*->\\s*$",
            "action": {
                "indent": "indent"
            }
        },
        {
            "beforeText": "^\\s*(end|exitwhen|break|skip|return)(\\s.*)?$",
            "action": {
                "indent": "outdent"
            }
        }
    ]
}
